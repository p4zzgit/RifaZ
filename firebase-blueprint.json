{
  "entities": {
    "GlobalConfig": {
      "title": "GlobalConfig",
      "description": "Global settings and landing page configuration controlled by Super Admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "platformName": { "type": "string" },
        "platformLogo": { "type": "string" },
        "platformBanner": { "type": "string" },
        "taxaPlataforma": { "type": "number" },
        "heroTitle": { "type": "string" },
        "heroSub": { "type": "string" },
        "heroBadge": { "type": "string" },
        "featuresTitle": { "type": "string" },
        "howItWorksTitle": { "type": "string" },
        "footerText": { "type": "string" },
        "mpAccessToken": { "type": "string" },
        "mpPublicKey": { "type": "string" }
      },
      "required": ["id", "platformName", "taxaPlataforma"]
    },
    "Usuario": {
      "title": "Usuario",
      "description": "User profile with super_admin or client roles",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string" },
        "usuario": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "client"] },
        "createdAt": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "nome", "email", "usuario", "role", "createdAt"]
    },
    "Rifa": {
      "title": "Rifa",
      "description": "Raffle campaign created by a client",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "nome": { "type": "string" },
        "slug": { "type": "string" },
        "tema": { "type": "string" },
        "corPrimaria": { "type": "string" },
        "corSecundaria": { "type": "string" },
        "descricao": { "type": "string" },
        "mensagemBoasVindas": { "type": "string" },
        "mensagemAgradecimento": { "type": "string" },
        "mensagemSucesso": { "type": "string" },
        "quantidadeCotas": { "type": "number" },
        "valorCota": { "type": "number" },
        "dataLimite": { "type": "string" },
        "totalVendido": { "type": "number" },
        "cotasVendidas": { "type": "number" },
        "saldoDisponivel": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "ownerId", "nome", "slug", "tema", "quantidadeCotas", "valorCota", "dataLimite", "status"]
    },
    "Participante": {
      "title": "Participante",
      "description": "Individual purchase in a raffle",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "rifaId": { "type": "string" },
        "nome": { "type": "string" },
        "whatsapp": { "type": "string" },
        "numeros": { "type": "array" },
        "valorTotal": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "rifaId", "nome", "whatsapp", "numeros", "valorTotal", "status", "createdAt"]
    },
    "Saque": {
      "title": "Saque",
      "description": "Withdrawal request from client to super admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "rifaId": { "type": "string" },
        "userId": { "type": "string" },
        "valorSolicitado": { "type": "number" },
        "taxaPlataforma": { "type": "number" },
        "valorLiquido": { "type": "number" },
        "chavePix": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "rifaId", "userId", "valorSolicitado", "taxaPlataforma", "valorLiquido", "chavePix", "status", "createdAt"]
    }
  },
  "firestore": {
    "/config/main": {
      "schema": "GlobalConfig",
      "description": "Global application configuration"
    },
    "/usuarios/{userId}": {
      "schema": "Usuario",
      "description": "App users"
    },
    "/rifas/{rifaId}": {
      "schema": "Rifa",
      "description": "Raffles created on the platform"
    },
    "/rifas/{rifaId}/participantes/{pId}": {
      "schema": "Participante",
      "description": "Participants of a specific raffle"
    },
    "/withdrawals/{wId}": {
      "schema": "Saque",
      "description": "Withdrawal requests stack"
    }
  }
}
